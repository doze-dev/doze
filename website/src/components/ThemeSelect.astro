---
// Replaces Starlight's theme dropdown with a three-segment toggle
// (System / Light / Dark). Uses the exact same storage key and semantics as
// Starlight — `starlight-theme` = 'light' | 'dark' | '' (empty means auto) —
// so it interops with Starlight's no-FOUC head script AND the registry site's
// toggle across doze.nerdmenot.in.
---

<starlight-theme-select>
  <div class="theme-seg" role="radiogroup" aria-label="Color theme">
    <button type="button" data-pref="auto" role="radio" aria-label="System theme" title="System">
      <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path fill="currentColor" d="M4 5h16a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1h-6l1 2h2a1 1 0 1 1 0 2H7a1 1 0 1 1 0-2h2l1-2H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm1 2v7h14V7H5Z"/></svg>
    </button>
    <button type="button" data-pref="light" role="radio" aria-label="Light theme" title="Light">
      <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path fill="currentColor" d="M12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10Zm0-5a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V3a1 1 0 0 1 1-1Zm0 17a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1ZM3 11a1 1 0 1 1 0 2H2a1 1 0 1 1 0-2h1Zm19 0a1 1 0 1 1 0 2h-1a1 1 0 1 1 0-2h1ZM5.6 4.2 6.3 5a1 1 0 0 1-1.4 1.4l-.7-.7A1 1 0 0 1 5.6 4.2Zm12.7 12.7.7.7a1 1 0 0 1-1.4 1.4l-.7-.7a1 1 0 0 1 1.4-1.4ZM4.2 18.4l.7-.7A1 1 0 0 1 6.3 19l-.7.7a1 1 0 0 1-1.4-1.3Zm12.7-12.7.7-.7a1 1 0 1 1 1.4 1.4l-.7.7a1 1 0 0 1-1.4-1.4Z"/></svg>
    </button>
    <button type="button" data-pref="dark" role="radio" aria-label="Dark theme" title="Dark">
      <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path fill="currentColor" d="M12.7 2.4a1 1 0 0 1 .2 1.1 7 7 0 0 0 9.2 9.2 1 1 0 0 1 1.3 1.3A9 9 0 1 1 11.6 2.2a1 1 0 0 1 1.1.2Z"/></svg>
    </button>
  </div>
</starlight-theme-select>

<script>
  const KEY = "starlight-theme";
  type Pref = "auto" | "light" | "dark";

  const loadPref = (): Pref => {
    const v = typeof localStorage !== "undefined" && localStorage.getItem(KEY);
    return v === "light" || v === "dark" ? v : "auto";
  };
  const storePref = (p: Pref) =>
    localStorage.setItem(KEY, p === "light" || p === "dark" ? p : "");
  const systemPref = (): "light" | "dark" =>
    matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";

  class ThemeSeg extends HTMLElement {
    buttons: HTMLButtonElement[] = [];
    constructor() {
      super();
      this.buttons = Array.from(this.querySelectorAll("button"));
      this.apply(loadPref());
      for (const b of this.buttons) {
        b.addEventListener("click", () => this.apply(b.dataset.pref as Pref));
      }
      matchMedia("(prefers-color-scheme: light)").addEventListener("change", () => {
        if (loadPref() === "auto") this.apply("auto");
      });
    }
    apply(pref: Pref) {
      document.documentElement.dataset.theme = pref === "auto" ? systemPref() : pref;
      storePref(pref);
      for (const b of this.buttons) {
        const on = b.dataset.pref === pref;
        b.setAttribute("aria-checked", String(on));
        b.classList.toggle("is-active", on);
      }
    }
  }
  customElements.define("starlight-theme-select", ThemeSeg);
</script>

<style>
  .theme-seg {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: 2px;
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 8px;
    background: var(--sl-color-bg-inline-code);
  }
  .theme-seg button {
    display: inline-grid;
    place-items: center;
    width: 28px;
    height: 24px;
    border: 0;
    border-radius: 6px;
    background: transparent;
    color: var(--sl-color-gray-3);
    cursor: pointer;
    transition:
      color 0.15s ease,
      background 0.15s ease;
  }
  .theme-seg button:hover {
    color: var(--sl-color-white);
  }
  .theme-seg button.is-active {
    background: var(--sl-color-accent);
    color: var(--sl-color-black); /* readable on the amber pill in both modes */
  }
</style>
